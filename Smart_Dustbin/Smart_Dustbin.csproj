<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
  </PropertyGroup>

  <ItemGroup>
    <None Remove="pic.jpg" />
    <None Remove="pic2.jpg" />
    <None Remove="pic22.jpg" />
    <None Remove="pic2_OG.jpg" />
    <None Remove="pic4.jpg" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="System.IO.Ports" Version="9.0.6" />
  </ItemGroup>

  <ItemGroup>
    <Resource Include="pic.jpg" />
    <Resource Include="pic2.jpg" />
    <Resource Include="pic22.jpg" />
    <Resource Include="pic2_OG.jpg" />
    <Resource Include="pic4.jpg" />
  </ItemGroup>

</Project>
