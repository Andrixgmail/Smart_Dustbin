<Window x:Class="Smart_Dustbin.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Smart_Dustbin"
        mc:Ignorable="d"
        Title="Smart Dustbin by Andrea Mahlo" Height="450" Width="800">

    <Window.Resources>
        <Style x:Key="RoundedButtonStyle" TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center" 
                                              Content="{TemplateBinding Content}" 
                                              ContentTemplate="{TemplateBinding ContentTemplate}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#FFB0B0B0"/>

                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>


    <Grid HorizontalAlignment="Center" Width="488" Height="430" VerticalAlignment="Top" Margin="0,10,0,0" >
        <Grid.Background>
            <ImageBrush  AlignmentX="Center" AlignmentY="Center" Stretch="UniformToFill" TileMode="None" ImageSource="/pic2_OG.jpg"/>
        </Grid.Background>
        <ProgressBar Name="dustbinProgressBar" 
                     Minimum="0" 
                     Maximum="100" 
                     Value="0"
                     HorizontalAlignment="Left" 
                     Height="187" 
                     VerticalAlignment="Top" 
                     Width="270" 
                     RenderTransformOrigin="0.445,0.45" Margin="111,129,0,0">
            <ProgressBar.Background>
                <ImageBrush TileMode="None">
                    <ImageBrush.RelativeTransform>
                        <TransformGroup>
                            <ScaleTransform CenterY="0.5" CenterX="0.5"/>
                            <SkewTransform CenterX="0.5" CenterY="0.5"/>
                            <RotateTransform Angle="90" CenterX="0.5" CenterY="0.5"/>
                            <TranslateTransform/>
                        </TransformGroup>
                    </ImageBrush.RelativeTransform>
                </ImageBrush>
            </ProgressBar.Background>
            <ProgressBar.RenderTransform>
                <TransformGroup>
                    <ScaleTransform/>
                    <SkewTransform/>
                    <RotateTransform Angle="-90.085"/>
                    <TranslateTransform X="4.996" Y="20.766"/>
                </TransformGroup>
            </ProgressBar.RenderTransform>
        </ProgressBar>
        <TextBlock Name="dustbinStatusText" 
                   HorizontalAlignment="Center" 
                   Margin="0,80,0,0" 
                   VerticalAlignment="Top" 
                   FontSize="36" 
                   FontWeight="Bold" 
                   Foreground="Black" 
                   TextWrapping="Wrap" 
                   Width="168" 
                   Height="84" 
                   TextAlignment="Center"
                   Text="0%" RenderTransformOrigin="0.5,0.5">
            <TextBlock.RenderTransform>
                <TransformGroup>
                    <ScaleTransform/>
                    <SkewTransform/>
                    <RotateTransform Angle="-0.601"/>
                    <TranslateTransform/>
                </TransformGroup>
            </TextBlock.RenderTransform>
        </TextBlock>
        <Button Content="Connect" 
                Name="ConnectButton" 
                Click="ConnectButton_Click"
                HorizontalAlignment="Left" 
                Margin="-87,57,0,0" 
                VerticalAlignment="Top" 
                Style="{StaticResource RoundedButtonStyle}"
                Height="40" Width="77" Background="#FFDDDDDD" BorderBrush="#FF978282"/>
        <ComboBox Name="PortComboBox" HorizontalAlignment="Left" Margin="10,75,0,0" VerticalAlignment="Top" Width="120"/>
        <Button Content="Disconnect" 
            x:Name="DisconnectButton" 
            Click="DisconnectButton_Click"
            HorizontalAlignment="Left" 
            Margin="-87,120,0,0" 
            VerticalAlignment="Top" 
            Style="{StaticResource RoundedButtonStyle}"
            Height="40" Width="77" Background="#FFDDDDDD" BorderBrush="#FF978282"/>
        <TextBlock x:Name="messagee" FontSize="36" HorizontalAlignment="Left" Margin="-87,231,0,0" TextWrapping="Wrap" VerticalAlignment="Top"/>
    </Grid>
</Window>
